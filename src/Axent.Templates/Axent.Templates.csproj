<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Axent.Templates</PackageId>
    <PackageType>Template</PackageType>
    <PackageTags>dotnet-new</PackageTags>
    <ContentTargetFolders>content</ContentTargetFolders>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="..\Axent.Templates.MinimalApi\**\*.*" 
             Pack="true" 
             PackagePath="content"
             Exclude="..\Axent.Templates.MinimalApi\**\bin\**;..\Axent.Templates.MinimalApi\**\obj\**;..\Axent.Templates.MinimalApi\**\.vs\**;..\Axent.Templates.MinimalApi\**\.git\**;" />
    <Compile Remove="**\*" />
  </ItemGroup>

</Project>
